# Required
DISCORD_TOKEN=your-discord-bot-token-here

# Optional: restrict access by user/channel/server IDs (comma-separated)
ALLOWED_USER_IDS=
ALLOWED_CHANNEL_IDS=
ALLOWED_GUILD_IDS=

# Ollama settings
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:26b

# Optional: custom system prompt
SYSTEM_PROMPT=

# Number of conversation turns to remember (default: 8)
HISTORY_TURNS=8

# Language: en or ja (default: en)
LANG=en
